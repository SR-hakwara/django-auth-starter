# =============================================================================
# django-auth-basic — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core — REQUIRED
# ---------------------------------------------------------------------------

# A long, random, unique secret key. NEVER commit the real key to version control.
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Enable debug mode (True in development, False in production)
DJANGO_DEBUG=True

# Comma-separated list of allowed hosts
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLite (default for development — do not use in production)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (recommended for production)
DATABASE_URL=postgres://user:password@localhost:5432/auth_starter_db

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------

# Use console backend for development (emails printed to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Use SMTP for production
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# ---------------------------------------------------------------------------
# Redis (required in production for shared, atomic rate limiting across workers)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Security (production only — set to True when behind HTTPS)
# ---------------------------------------------------------------------------
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
